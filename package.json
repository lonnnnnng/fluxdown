{
  "name": "fluxdown",
  "private": true,
  "version": "1.0.3",
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "desktop:dev": "npm --workspace apps/desktop run tauri:dev",
    "desktop:clean": "node scripts/clean-tauri-temp.mjs",
    "desktop:build": "npm --workspace apps/desktop run tauri:build",
    "desktop:dmg": "npm --workspace apps/desktop run tauri:dmg",
    "desktop:web": "npm --workspace apps/desktop run dev --",
    "mobile:analyze": "cd apps/mobile && flutter analyze",
    "mobile:test": "cd apps/mobile && flutter test",
    "mobile:android": "cd apps/mobile && flutter build apk --debug",
    "mobile:android:release": "cd apps/mobile && flutter build apk --release",
    "mobile:android:aab": "cd apps/mobile/android && ./gradlew bundleRelease",
    "mobile:ios:simulator": "cd apps/mobile && flutter build ios --simulator",
    "mobile:ios:framework": "cd apps/mobile && LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 flutter build ios-framework --no-profile --no-release",
    "mobile:ios:framework:verify": "node scripts/verify-artifacts.mjs ios-framework",
    "mobile:ios:ipa": "cd apps/mobile && LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 flutter build ipa --export-options-plist=ios/ExportOptions.plist",
    "mobile:ios:ipa:signed": "bash scripts/build-ios-ipa-local.sh",
    "mobile:ios": "cd apps/mobile && LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 flutter build ios --no-codesign",
    "mobile:ios:simulator:verify": "node scripts/verify-artifacts.mjs ios-simulator",
    "mobile:ios:verify": "node scripts/verify-artifacts.mjs ios-device-unsigned",
    "verify:artifacts": "node scripts/verify-artifacts.mjs local",
    "verify:linux-cli": "node scripts/verify-artifacts.mjs linux-cli",
    "verify:linux-gui": "node scripts/verify-artifacts.mjs linux-gui",
    "verify:windows-cli": "node scripts/verify-artifacts.mjs windows-cli",
    "verify:windows-gui": "node scripts/verify-artifacts.mjs windows-gui",
    "verify:macos": "bash scripts/verify-macos.sh",
    "verify:macos-artifacts": "node scripts/verify-macos-artifacts.mjs",
    "verify:macos-cli-artifact": "node scripts/verify-macos-artifacts.mjs cli",
    "verify:macos-cli-release": "bash scripts/verify-macos-cli-release.sh",
    "verify:macos-cli-release-http-hls": "FLUXDOWN_BIN=target/release/fluxdown bash scripts/verify-macos-cli-http-hls.sh",
    "verify:macos-cli-release-ftp-ftps": "FLUXDOWN_BIN=target/release/fluxdown bash scripts/verify-macos-cli-ftp-ftps.sh",
    "verify:macos-cli-release-sftp": "FLUXDOWN_BIN=target/release/fluxdown bash scripts/verify-macos-cli-sftp.sh",
    "verify:macos-cli-release-smb": "FLUXDOWN_BIN=target/release/fluxdown bash scripts/verify-macos-cli-smb.sh",
    "verify:macos-cli-release-p2p": "FLUXDOWN_BIN=target/release/fluxdown bash scripts/verify-macos-cli-p2p.sh",
    "verify:macos-cli-release-queue-controls": "FLUXDOWN_BIN=target/release/fluxdown bash scripts/verify-macos-cli-queue-controls.sh",
    "verify:macos-cli-ftp-ftps": "bash scripts/verify-macos-cli-ftp-ftps.sh",
    "verify:macos-cli-http-hls": "bash scripts/verify-macos-cli-http-hls.sh",
    "verify:macos-cli-p2p": "bash scripts/verify-macos-cli-p2p.sh",
    "verify:macos-cli-queue-controls": "bash scripts/verify-macos-cli-queue-controls.sh",
    "verify:macos-cli-sftp": "bash scripts/verify-macos-cli-sftp.sh",
    "verify:macos-cli-smb": "bash scripts/verify-macos-cli-smb.sh",
    "verify:macos-desktop-command": "bash scripts/verify-macos-desktop-command.sh",
    "verify:macos-desktop-ftps": "bash scripts/verify-macos-desktop-ftps.sh",
    "verify:macos-desktop-p2p": "bash scripts/verify-macos-desktop-p2p.sh",
    "verify:macos-desktop-smb": "bash scripts/verify-macos-desktop-smb.sh",
    "verify:macos-desktop-sftp": "bash scripts/verify-macos-desktop-sftp.sh",
    "verify:apple": "bash scripts/verify-apple.sh",
    "verify:ios": "bash scripts/verify-ios.sh",
    "verify:ios:device-readiness": "node scripts/verify-ios-device-readiness.mjs",
    "verify:ios:signing-readiness": "node scripts/verify-ios-signing-readiness.mjs",
    "verify:ios:integration": "bash scripts/verify-ios-integration.sh",
    "verify:release": "node scripts/verify-artifacts.mjs release",
    "verify:ci-config": "node scripts/verify-artifacts.mjs ci-config",
    "verify:licenses": "node scripts/verify-licenses.mjs",
    "verify:mobile-url-schemes": "node scripts/verify-mobile-url-schemes.mjs",
    "release:stage": "node scripts/stage-release.mjs",
    "release:manifest": "node scripts/release-manifest.mjs write",
    "release:manifest:verify": "node scripts/release-manifest.mjs verify",
    "release:prepare": "npm run release:stage && npm run release:manifest && npm run verify:release && npm run release:manifest:verify",
    "audit:release": "node scripts/audit-release-readiness.mjs",
    "desktop:windows-cli:docker": "bash scripts/build-windows-cli-docker.sh",
    "desktop:windows-gui:docker": "bash scripts/build-windows-gui-docker.sh",
    "desktop:linux:docker": "bash scripts/build-linux-gui-docker.sh",
    "test": "cargo test --workspace && npm --workspace apps/desktop run build && cd apps/mobile && flutter test"
  }
}
